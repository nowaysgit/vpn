{
  "name": "@vpn/admin-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --host 0.0.0.0 --port 3002",
    "build": "nuxt build",
    "preview": "nuxt preview --host 0.0.0.0 --port 3002",
    "serve:e2e": "bun run build && bun .output/server/index.mjs",
    "serve:built": "bun .output/server/index.mjs",
    "lint": "eslint app nuxt.config.ts test",
    "lint:fix": "eslint app nuxt.config.ts test --fix",
    "typecheck": "nuxt typecheck",
    "test": "bun test",
    "ci:check": "bun run lint && bun run typecheck && bun run test",
    "ci:fix": "bun run lint:fix"
  },
  "dependencies": {
    "@elysiajs/eden": "latest",
    "@lucide/vue": "^1.21.0",
    "@vpn/api-contract": "workspace:*",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "nuxt": "latest",
    "reka-ui": "^2.10.0",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "latest",
    "tailwindcss": "^4.3.1",
    "typescript": "latest",
    "vue-tsc": "latest"
  }
