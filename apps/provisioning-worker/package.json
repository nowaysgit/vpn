{
  "name": "@vpn/provisioning-worker",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci:check": "bun run lint && bun run typecheck && bun run test",
    "ci:fix": "bun run lint:fix"
  },
  "dependencies": {
    "@vpn/api-contract": "workspace:*",
    "@vpn/provider-contract": "workspace:*",
    "pg-boss": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
